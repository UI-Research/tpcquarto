detect_model_version <- function(output.file) {
output <- readLines(
con = output.file,
warn = FALSE
) |>
unlist()
text <- output[substr(output,1,9) == " DATABASE"]
version <- str_sub(str_remove(text, ".st2"), start = nchar(text) - 9, end = nchar(text))
return(version)
}
